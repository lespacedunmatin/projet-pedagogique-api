# Configuration Base de Données
DB_HOST=localhost
DB_PORT=3306
DB_USER=app_projet_peda
DB_PASSWORD=JeR@swY&LM6Jja!o6hL&
DB_ROOT_PASSWORD=''
DB_NAME=projet_pedagogique

# Environnement
NODE_ENV=development
PORT=3000

# Session
SESSION_SECRET=votre_clé_secrète_très_sécurisée_ici

# CORS - Origines autorisées (séparées par des virgules)
# Exemples:
# - http://localhost:3000 (API elle-même)
# - http://localhost:4200 (Client Angular)
# - http://localhost:3001 (Client React)
# - https://app.exemple.com (Production)
CORS_ORIGIN=http://localhost:3000,http://localhost:4200,http://localhost:3001

# Notes:
# - DB_PASSWORD : laisser vide si pas de mot de passe (configuration par défaut de MariaDB, ça ne devrait pas arriver.
#                 Si ça arrive, contactez votre administrateur pour qu'il change ça).
#                 Et n'utilisez pas JeR@swY&LM6Jja!o6hL& comme mot de passe en production.
# - DB_ROOT_PASSWORD : A effacer après initialisation de la base de données.
# - NODE_ENV : development pour les logs détaillés, production pour mode optimisé
# - SESSION_SECRET : Générer une clé cryptographiquement sécurisée en production (voir documentation)
# - CORS_ORIGIN : Configurer selon vos clients frontend (développement et production)
